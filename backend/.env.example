# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/avoindia?retryWrites=true&w=majority

# Admin panel password (you choose this)
ADMIN_PASSWORD=your_strong_admin_password_here

# Secret key for signing JWT tokens (use a long random string)
JWT_SECRET=change_this_to_a_long_random_secret_string_minimum_32_chars